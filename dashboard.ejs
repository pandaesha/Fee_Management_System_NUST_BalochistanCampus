<!DOCTYPE html>
<html>
<head>
    <title>Dashboard - <%= student.name %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f4f7fa; font-family: 'Segoe UI', Tahoma, sans-serif; }
        .nust-header { background-color: #003366; color: white; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,51,102,0.15); }
        .nust-text { color: #003366; font-weight: bold; }
        .btn-nust { background-color: #003366; color: white; }
        .btn-nust:hover { background-color: #001f3f; color: white; }
        .table-nust-header { background-color: #003366 !important; color: white !important; }
        .custom-card { border-radius: 12px; border: none; box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
        .badge-scholarship { background-color: #e0eaf5; color: #003366; border: 1px solid #8ba3c7; }
    </style>
</head>
<body>

<div class="container mt-5">
    <!-- Header Card -->
    <div class="card nust-header mb-4 border-0 p-2">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h2 class="fw-bold mb-1">Welcome, <%= student.name %>!</h2>
                <p class="mb-0 text-light opacity-75" style="font-size: 1.1rem;">
                    Roll No: <b><%= student.student_id %></b> | 
                    <!-- UPDATED: Department and Semester -->
                    Department: <b><%= student.department %></b> | 
                    Semester: <b><%= student.semester %></b>
                    
                    <% if(student.scholarship && student.scholarship !== "None" && student.scholarship !== "No") { %>
                        | <span class="badge badge-scholarship fs-6 ms-2 shadow-sm">🎓 <%= student.scholarship %></span>
                    <% } %>
                </p>
            </div>
            <a href="/" class="btn btn-light text-danger fw-bold shadow-sm">Logout</a>
        </div>
    </div>

    <h4 class="mb-3 nust-text">📄 Financial Record</h4>
    <div class="card custom-card">
        <div class="card-body table-responsive p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-nust-header">
                    <tr>
                        <th class="py-3 px-3">Voucher ID</th>
                        <th class="py-3">Total Amount</th>
                        <th class="py-3">Scholarship</th>
                        <th class="py-3">Fee Breakdown</th>
                        <th class="py-3">Due Date</th>
                        <th class="py-3">Status</th>
                        <th class="py-3 px-3">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% vouchers.forEach(function(voucher) { %>
                        <tr>
                            <td class="px-3"><b><%= voucher.voucher_id %></b></td>
                            <td class="text-success fw-bold">Rs. <%= voucher.amount || voucher.total_amount %></td>
                            
                            <td>
                                <% if(student.scholarship && student.scholarship !== "None" && student.scholarship !== "No" && student.scholarship !== "") { %>
                                    <span class="badge badge-scholarship">🎓 <%= student.scholarship %></span>
                                <% } else { %>
                                    <span class="text-muted"><small>No Scholarship</small></span>
                                <% } %>
                            </td>

                            <td>
                                <ul class="mb-0 text-muted" style="padding-left: 15px; font-size: 0.9rem;">
                                    <% voucher.fee_breakdown.forEach(function(fee) { %>
                                        <li><%= fee.fee_type %>: <%= fee.amount %></li>
                                    <% }) %>
                                </ul>
                            </td>
                            <td><%= voucher.due_date.toDateString() %></td>
                            <td>
                                <% if(voucher.status === 'paid') { %>
                                    <span class="badge bg-success rounded-pill px-3 py-2">Paid</span>
                                <% } else if(voucher.status === 'overdue') { %>
                                    <span class="badge bg-danger rounded-pill px-3 py-2">Overdue</span>
                                <% } else { %>
                                    <span class="badge bg-warning text-dark rounded-pill px-3 py-2 shadow-sm">Pending</span>
                                <% } %>
                            </td>
                            <td class="px-3">
                                <% if(voucher.status !== 'paid') { %>
                                    <a href="/pay/<%= voucher.voucher_id %>" class="btn btn-sm btn-nust shadow-sm">Pay Now</a>
                                <% } else { %>
                                    <button class="btn btn-sm btn-secondary opacity-50" disabled>Cleared</button>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

</body>
</html>