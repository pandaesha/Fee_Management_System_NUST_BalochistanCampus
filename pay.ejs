<!DOCTYPE html>
<html>
<head>
    <title>Process Payment - <%= voucher.voucher_id %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<div class="container mt-5" style="max-width: 800px;">
    <a href="/dashboard/<%= student.student_id %>" class="btn btn-outline-secondary mb-3">← Back to Dashboard</a>
    
    <h3 class="text-primary mb-4">💳 Payment Options for Voucher: <%= voucher.voucher_id %></h3>

    <!-- Option 1: Pay Full Amount -->
    <div class="card shadow-sm border-success mb-4">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0">Option 1: Pay Full Voucher Amount</h5>
        </div>
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h4 class="text-success mb-0">Rs. <%= voucher.amount || voucher.total_amount %></h4>
                <p class="text-muted mb-0">Pay the complete fee at once. All installments will be cancelled.</p>
            </div>
            <!-- CHANGED TO GET METHOD TO SHOW CHALLAN -->
            <form action="/challan/full/<%= voucher.voucher_id %>" method="GET">
                <button type="submit" class="btn btn-success btn-lg">View Voucher & Pay</button>
            </form>
        </div>
    </div>

    <!-- Option 2: Pay Installments -->
    <div class="card shadow-sm border-primary">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Option 2: Pay in Installments</h5>
        </div>
        <div class="card-body">
            <p class="text-muted">You can pay your fee in 2 easy installments.</p>
            
            <ul class="list-group">
                <% installments.forEach(function(inst) { %>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <div>
                            <strong>Installment <%= inst.installment_number %></strong><br>
                            Due: <%= inst.due_date.toDateString() %>
                        </div>
                        <div class="d-flex align-items-center">
                            <h5 class="me-4 mb-0">Rs. <%= inst.amount %></h5>
                            
                            <% if(inst.status === 'paid') { %>
                                <span class="badge bg-success fs-6">Paid</span>
                            <% } else { %>
                                <!-- CHANGED TO GET METHOD TO SHOW CHALLAN -->
                                <form action="/challan/installment/<%= inst.installment_id %>" method="GET" class="m-0">
                                    <button type="submit" class="btn btn-primary">View Challan</button>
                                </form>
                            <% } %>
                        </div>
                    </li>
                <% }) %>
            </ul>
        </div>
    </div>
</div>

</body>
</html>